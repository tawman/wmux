{
  "appId": "com.wmux.app",
  "productName": "wmux",
  "npmRebuild": false,
  "directories": {
    "output": "release"
  },
  "publish": {
    "provider": "github",
    "owner": "amirlehmam",
    "repo": "wmux"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "node_modules/**/*",
    "!**/*.ts",
    "!**/*.tsx",
    "!src/**/*",
    "!docs/**/*",
    "!tests/**/*"
  ],
  "asarUnpack": [
    "**/*.node"
  ],
  "win": {
    "icon": "resources/icons/icon.ico",
    "publisherName": ["SignPath Foundation"],
    "target": [
      { "target": "dir", "arch": ["x64"] }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "wmux"
  },
  "portable": {
    "artifactName": "wmux-${version}-portable.exe"
  },
  "extraResources": [
    { "from": "resources/icon.png", "to": "icon.png" },
    { "from": "resources/themes", "to": "themes" },
    { "from": "resources/sounds", "to": "sounds" },
    { "from": "resources/claude-instructions.md", "to": "claude-instructions/claude-instructions.md" },
    { "from": "src/shell-integration", "to": "shell-integration" },
    { "from": "dist/cli/wmux.js", "to": "cli/wmux.js" },
    { "from": "resources/wmux-orchestrator", "to": "wmux-orchestrator" }
  ]
}
