{
  "name": "wmux",
  "version": "0.24.0-local.1",
  "description": "Windows terminal multiplexer for AI agents",
  "license": "MIT",
  "main": "dist/main/index.js",
  "bin": {
    "wmux": "dist/cli/wmux.js"
  },
  "scripts": {
    "dev": "concurrently \"vite --port 5199\" \"wait-on http://localhost:5199 && electron .\"",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:main": "tsc -p tsconfig.node.json",
    "build:renderer": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@types/ws": "8.18.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-image": "0.9.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-search": "0.16.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/addon-webgl": "0.19.0",
    "@xterm/xterm": "6.0.0",
    "dompurify": "3.4.11",
    "electron-updater": "6.8.9",
    "marked": "18.0.5",
    "node-pty": "1.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "uuid": "11.1.1",
    "ws": "8.21.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "eslint": "10.6.0",
    "rcedit": "5.0.2",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "wait-on": "9.0.10"
  }
}
